# ─────────────────────────────────────────────
# ProNobat Website — Environment Variables
# Copy this file to .env.local for local dev.
# On Vercel, set these in Project > Settings > Environment Variables.
# ─────────────────────────────────────────────

# Public site URL (no trailing slash).
# Used for canonical links, OG images, sitemap, and schema.org markup.
NEXT_PUBLIC_SITE_URL=https://pronobat.ir

# RTL-Theme product listing URL for the plugin purchase CTA.
# Leave empty or omit until the plugin page is published — all buy buttons
# will fall back to "#" and still render safely.
NEXT_PUBLIC_RTL_THEME_URL=https://www.rtl-theme.com/product/pronobat/
